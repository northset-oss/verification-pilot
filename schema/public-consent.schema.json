{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://northset-oss.github.io/verification-pilot/schema/public-consent.schema.json",
  "title": "Northset public consent receipt",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "mission_id", "variant", "consent_artifact", "granted_at", "granted_by", "publication_consent", "scope"],
  "properties": {
    "schema_version": { "const": 1 },
    "mission_id": { "type": "string", "pattern": "^M-(?:[0-9]{3,}|E2[a-c])$" },
    "variant": { "enum": ["V", "W", "F"] },
    "consent_artifact": { "type": "string", "format": "uri", "pattern": "^https://" },
    "granted_at": { "type": "string", "format": "date-time" },
    "granted_by": { "type": "string", "minLength": 1 },
    "publication_consent": { "const": true },
    "scope": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
  }
}
