{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://northset-oss.github.io/verification-pilot/schema/public-receipt.schema.json",
  "title": "Northset public proof-of-pass receipt",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "generated_at", "receipt_id", "receipt_result", "passed_commands", "declared_commands", "timestamps", "commands", "environment", "code", "execution_summary", "bundle", "classification", "links", "issue_title", "limitations", "correction", "scope_note", "upstream_outcome"],
  "properties": {
    "schema_version": { "enum": [1, 2] },
    "generated_at": { "$ref": "#/$defs/time" },
    "receipt_id": { "$ref": "#/$defs/missionId" },
    "receipt_result": { "type": "string", "pattern": "^PASS — [0-9]+/[0-9]+ declared commands?$" },
    "passed_commands": { "type": "integer", "minimum": 0 },
    "declared_commands": { "type": "integer", "minimum": 0 },
    "timestamps": {
      "type": "object", "additionalProperties": false,
      "required": ["started_at", "finished_at"],
      "properties": { "started_at": { "$ref": "#/$defs/time" }, "finished_at": { "$ref": "#/$defs/time" } }
    },
    "commands": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/command" } },
    "environment": {
      "type": "object", "additionalProperties": false,
      "required": ["container_image_ref", "container_image_digest", "container_image_id", "container_os", "container_architecture", "network_policy", "source_commit", "install_commands"],
      "properties": {
        "container_image_ref": { "type": "string", "minLength": 1 },
        "container_image_digest": { "$ref": "#/$defs/nullableImageDigest" },
        "container_image_id": { "$ref": "#/$defs/nullableDigest" },
        "container_os": { "$ref": "#/$defs/nullableString" },
        "container_architecture": { "$ref": "#/$defs/nullableString" },
        "network_policy": { "type": "string", "minLength": 1 },
        "workspace_mode": { "type": ["string", "null"], "enum": ["readonly", "writable_copy", null] },
        "workspace_write_allowlist": { "type": "array", "maxItems": 32, "items": { "type": "string", "minLength": 1 } },
        "workspace_file_count_limit": { "type": ["integer", "null"], "minimum": 1 },
        "workspace_bytes_limit": { "type": ["integer", "null"], "minimum": 1 },
        "initial_workspace_manifest_digest": { "$ref": "#/$defs/nullableDigest" },
        "post_run_changed_tracked_paths": { "type": "array", "items": { "type": "string" } },
        "post_run_untracked_paths": { "type": "array", "items": { "type": "string" } },
        "post_run_mode_changes": { "type": "array", "items": { "type": "string" } },
        "source_commit": { "$ref": "#/$defs/nullableOid" },
        "install_commands": { "type": "array", "items": { "type": "string" } }
      }
    },
    "code": {
      "type": "object", "additionalProperties": false,
      "required": ["base_commit", "recorded_patch_commit", "patch_commit_binding", "patch_diff_hash", "patch_diff_binding"],
      "properties": {
        "base_commit": { "$ref": "#/$defs/nullableOid" },
        "recorded_patch_commit": { "$ref": "#/$defs/nullableOid" },
        "patch_commit_binding": { "const": "declared metadata; not execution-bound" },
        "patch_diff_hash": { "$ref": "#/$defs/nullableDigest" },
        "patch_diff_binding": { "enum": ["no patch recorded", "bound to executed patch bytes"] }
      }
    },
    "execution_summary": { "type": "string", "minLength": 1 },
    "bundle": {
      "type": "object", "additionalProperties": false,
      "required": ["bundle_contents_digest", "signed_asset_sha256", "attestation_uri", "attestation_verified_at", "provenance"],
      "properties": {
        "bundle_contents_digest": { "$ref": "#/$defs/digest" },
        "signed_asset_sha256": { "$ref": "#/$defs/nullableDigest" },
        "attestation_uri": { "$ref": "#/$defs/nullableUrl" },
        "attestation_verified_at": { "anyOf": [{ "$ref": "#/$defs/time" }, { "type": "null" }] },
        "provenance": { "type": "string", "minLength": 1 }
      }
    },
    "classification": { "type": "string", "minLength": 1 },
    "links": {
      "type": "object", "additionalProperties": false,
      "required": ["canonical_url", "target_repo", "issue_or_task", "publication_pr"],
      "properties": {
        "canonical_url": { "type": "string", "format": "uri" },
        "target_repo": { "type": "string", "format": "uri" },
        "issue_or_task": { "$ref": "#/$defs/nullableUrl" },
        "publication_pr": { "$ref": "#/$defs/nullableUrl" }
      }
    },
    "issue_title": { "$ref": "#/$defs/nullableString" },
    "limitations": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "correction": { "$ref": "#/$defs/nullableString" },
    "scope_note": { "$ref": "#/$defs/nullableString" },
    "upstream_outcome": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object", "additionalProperties": false,
          "required": ["status", "link", "attribution"],
          "properties": {
            "status": { "type": "string", "minLength": 1 },
            "link": { "$ref": "#/$defs/nullableUrl" },
            "attribution": { "type": "string", "minLength": 1 },
            "head_drift": { "const": true },
            "pr_head_oid": { "$ref": "#/$defs/nullableOid" }
          }
        }
      ]
    },
    "economic_identity": { "$ref": "economic-identity.schema.json#/$defs/publicEconomicIdentity" }
  },
  "allOf": [{
    "if": {
      "properties": {
        "upstream_outcome": {
          "type": "object",
          "properties": { "status": { "const": "prepared" } },
          "required": ["status"]
        }
      },
      "required": ["upstream_outcome"]
    },
    "then": { "properties": { "bundle": { "oneOf": [{
      "properties": {
        "signed_asset_sha256": { "type": "null" },
        "attestation_uri": { "type": "null" },
        "attestation_verified_at": { "type": "null" },
        "provenance": { "const": "Signed provenance has not been verified." }
      }
    }, {
      "properties": {
        "signed_asset_sha256": { "$ref": "#/$defs/digest" },
        "attestation_uri": { "type": "string", "format": "uri" },
        "attestation_verified_at": { "$ref": "#/$defs/time" },
        "provenance": { "const": "Signed provenance recorded; the signer records artifact origin, not execution witnessing or maintainer approval." }
      }
    }] } } },
    "else": { "properties": { "bundle": { "properties": {
      "signed_asset_sha256": { "$ref": "#/$defs/digest" },
      "attestation_uri": { "type": "string", "format": "uri" },
      "attestation_verified_at": { "$ref": "#/$defs/time" },
      "provenance": { "const": "Signed provenance recorded; the signer records artifact origin, not execution witnessing or maintainer approval." }
    } } } }
  }, {
    "if": { "properties": { "schema_version": { "const": 2 } }, "required": ["schema_version"] },
    "then": { "required": ["economic_identity"] },
    "else": { "not": { "required": ["economic_identity"] } }
  }, {
    "if": {
      "properties": { "environment": { "properties": { "workspace_mode": { "type": "string" } }, "required": ["workspace_mode"] } },
      "required": ["environment"]
    },
    "then": {
      "properties": {
        "environment": {
          "required": ["workspace_write_allowlist", "workspace_file_count_limit", "workspace_bytes_limit", "initial_workspace_manifest_digest", "post_run_changed_tracked_paths", "post_run_untracked_paths", "post_run_mode_changes"]
        }
      }
    }
  }, {
    "if": {
      "properties": {
        "environment": {
          "anyOf": [
            { "required": ["workspace_write_allowlist"] },
            { "required": ["workspace_file_count_limit"] },
            { "required": ["workspace_bytes_limit"] },
            { "required": ["initial_workspace_manifest_digest"] },
            { "required": ["post_run_changed_tracked_paths"] },
            { "required": ["post_run_untracked_paths"] },
            { "required": ["post_run_mode_changes"] }
          ]
        }
      },
      "required": ["environment"]
    },
    "then": { "properties": { "environment": { "required": ["workspace_mode"] } } }
  }],
  "$defs": {
    "missionId": { "type": "string", "pattern": "^M-(?:[0-9]{3}|E2[a-c])$" },
    "time": { "type": "string", "format": "date-time" },
    "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "nullableDigest": { "type": ["string", "null"], "pattern": "^sha256:[0-9a-f]{64}$" },
    "nullableImageDigest": { "type": ["string", "null"], "pattern": "^(?:[^@ ]+@)?sha256:[0-9a-f]{64}$" },
    "nullableOid": { "type": ["string", "null"], "pattern": "^[0-9a-f]{40}$" },
    "nullableString": { "type": ["string", "null"], "minLength": 1 },
    "nullableUrl": { "type": ["string", "null"], "format": "uri" },
    "command": {
      "type": "object", "additionalProperties": false,
      "required": ["cmd", "exit_code", "timed_out", "duration_ms"],
      "properties": {
        "cmd": { "type": "string", "minLength": 1 },
        "exit_code": { "type": ["integer", "null"] },
        "timed_out": { "type": "boolean" },
        "duration_ms": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
